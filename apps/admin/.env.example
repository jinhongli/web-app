NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Shared SSO session (see packages/auth). Public origins of each app, used to
# build cross-app login redirects. Defaults match the dev ports.
NEXT_PUBLIC_WEB_URL=http://localhost:3520
NEXT_PUBLIC_ADMIN_URL=http://localhost:3521
NEXT_PUBLIC_DOC_URL=http://localhost:3522

# Name of the cookie holding the shared session.
NEXT_PUBLIC_AUTH_COOKIE_NAME=webapp_sso
# Parent domain the session cookie is scoped to in production (e.g. .example.com).
# Leave unset in development so the cookie is shared across localhost ports.
# NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=
